# ── Environment ──────────────────────────────────────────────────────────────
 .env
 *.env

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Data — never commit raw or processed data to Git ─────────────────────────
data/raw/*
data/processed/*
data/models/*

!data/raw/.gitkeep
!data/processed/.gitkeep
!data/models/.gitkeep

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── OS garbage ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter (if you explore data in notebooks) ────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log